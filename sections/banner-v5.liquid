

<div {% render 'section-attr' %}>
  {% render 'section-bg-image' %}
  <xo-container
    {% render 'section-layout' %}
  >
    <xo-animate>
      <xo-grid style='min-height: 560px; align-items: center;'>
        <div class='banner-v200__item-main' style='--lg: 4; --xs: 12;'>
          <div class='banner-v200__text-main'>
            <p class='banner-v200__subtitle'>{{ section.settings.subtitle1 }}</p>
            <h4 class='banner-v200__title-main'>{{ section.settings.title1 }}</h4>
            <p class='banner-v200__description'>{{ section.settings.description1 }}</p>
            {% render 'button',
              text: section.settings.button_text1,
              link: section.settings.link_banner1,
              mode: section.settings.button_mode1,
              style: section.settings.button_style1,
              size: section.settings.button_size1,
              radius: section.settings.button_radius1,
              padding: section.settings.button_padding1
            %}
          </div>
          <div class='bg_sample'></div>
        </div>
        <div class='banner-v200__item' style='--lg: 8; --xs: 12;'>
          <xo-grid>
            <div
              class='{% render 'hover-style' %}'
              style='--lg: 6; --xs: 12; --xo-grid-col-gap: {{section.settings.gap}}px; position: relative;'
            >
              <a class='banner-v200__img-link' href='{{ section.settings.link_banner2 }}'>
                {% render 'image', image: section.settings.img_banner2 %}
              </a>
              <div class='banner-v200__text'>
                <h3 class='banner-v200__title'>{{ section.settings.title2 }}</h3>
              </div>
            </div>
            <div
              class='{% render 'hover-style' %}'
              style='--lg: 6; --xs: 12; --xo-grid-col-gap: {{section.settings.gap}}px; position: relative;'
            >
              <div class='banner-v200__border'>
                <a class='banner-v200__img-link' href='{{ section.settings.link_banner3 }}'>
                  {% render 'image', image: section.settings.img_banner3 %}
                </a>
              </div>
              <div class='banner-v200__text'>
                <h3 class='banner-v200__title'>{{ section.settings.title3 }}</h3>
              </div>
            </div>
          </xo-grid>
        </div>
      </xo-grid>
    </xo-animate>
  </xo-container>
</div>

