

<div class='banner-v240'>
  <div
    {% render 'section-attr' %}
  >
    {% render 'section-bg-image' %}
    <div
      class='banner-v240__bg'
      {%- if section.settings.bg -%}
        style='--bg: {{ section.settings.bg }}; --percent-height: {{ section.settings.bg_percentage_height }}%; --percent-width: {{ section.settings.bg_percentage_width }}%'
      {%- endif -%}
    ></div>
    <xo-container
      {% render 'section-layout' %}
    >
      <xo-animate xo-cascade>
        <xo-grid
          class="banner-v240"
          style='--xs:1;--md:3;--xo-grid-col-gap:{{ section.settings.gap }}px ;--xo-grid-row-gap:{{ section.settings.gap }}px ;'
        >
          <div class='banner-v240__item banner-v240__item-first'>
            <div class='banner-v240__item-wrap'>
              <h2  class="banner-v240__title1">{{ section.settings.title1 }}</h2>
              <div class='{%- render 'hover-style' -%}'>
                <a href='{{ section.settings.link_banner1 }}' class='banner-v240__img-link'>
                  {% render 'image', image: section.settings.image1 %}
                </a>
              </div>
            </div>
          </div>
          <div class='banner-v240__item'>
            <div class='banner-v240__item-wrap'>
              <div class='{%- render 'hover-style' -%}'>
                <a href='{{ section.settings.link_banner2 }}' class='banner-v240__img-link__center'>
                  {% render 'image', image: section.settings.image2 %}
                </a>
              </div>
              <div class='banner-v240__content'>
                <h3 class="banner-v240__subtitle">{{ section.settings.subtitle }}</h3>
                <h3 class="banner-v240__title-center">{{ section.settings.titleCenter }}</h3>
                {% render 'button',
                  text: section.settings.button_text,
                  link: section.settings.link_banner,
                  mode: section.settings.button_mode,
                  style: section.settings.button_style,
                  size: section.settings.button_size,
                  radius: section.settings.button_radius,
                  padding: section.settings.button_padding
                %}
              </div>
            </div>
          </div>
          <div class='banner-v240__item banner-v240__item-last'>
            <div class='banner-v240__item-wrap'>
              <div class='{%- render 'hover-style' -%}'>
                <a href='{{ section.settings.link_banner3 }}' class='banner-v240__img-link'>
                  {% render 'image', image: section.settings.image3 %}
                </a>
              </div>
               <h2  class="banner-v240__title2">{{ section.settings.title2 }}</h2> 
            </div>
          </div>
        </xo-grid>
      </xo-animate>
    </xo-container>
  </div>
</div>

