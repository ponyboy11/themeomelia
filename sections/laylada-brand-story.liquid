<section class="laylada-section">
  <div class="laylada-container">
    <div class="laylada-grid laylada-grid--2">
      <div>
        <p class="laylada-eyebrow">Our vision</p>
        <h2 class="laylada-heading">{{ section.settings.heading }}</h2>
        <p class="laylada-subheading">{{ section.settings.subheading }}</p>
        <div class="laylada-pill-list">
          <span class="laylada-pill">Inclusive</span>
          <span class="laylada-pill">Elegant</span>
          <span class="laylada-pill">Wearable</span>
          <span class="laylada-pill">Seasonless</span>
        </div>
      </div>
      <div class="laylada-card">
        <div class="laylada-card__body">
          <p class="laylada-quote">“Fashion should not divide, but unify.”</p>
          <p class="laylada-card__text">At Laylada, clean silhouettes, modern details, and modest elements come together to create a balanced and refined style identity for every woman, every season.</p>
          <a class="laylada-link" href="{{ routes.root_url }}pages/about">Discover LAYLADA</a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Laylada brand story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Modern modesty with a contemporary touch"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "At Laylada, we bridge modest wear and modern Western fashion — creating styles that are inclusive, elegant, and wearable for every woman, every season."
    }
  ],
  "presets": [
    {
      "name": "Laylada brand story"
    }
  ]
}
{% endschema %}
