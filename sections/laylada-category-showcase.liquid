<section class="laylada-section">
  <div class="laylada-container">
    <div class="laylada-header">
      <div>
        <p class="laylada-eyebrow">Curated collections</p>
        <h2 class="laylada-heading">{{ section.settings.heading }}</h2>
      </div>
      <p class="laylada-subheading">{{ section.settings.subheading }}</p>
    </div>
    <div class="laylada-grid laylada-grid--4">
      <a class="laylada-card" href="{{ routes.collections_url }}/dubai-collection">
        <div class="laylada-media" aria-hidden="true"></div>
        <div class="laylada-card__body">
          <h3 class="laylada-card__title">Dubai Collection</h3>
          <p class="laylada-card__text">Luxury abayas, kimonos, and elevated occasion pieces inspired by Dubai elegance.</p>
          <span class="laylada-link">Explore Dubai</span>
        </div>
      </a>
      <a class="laylada-card" href="{{ routes.collections_url }}/malaga-collection">
        <div class="laylada-media" aria-hidden="true"></div>
        <div class="laylada-card__body">
          <h3 class="laylada-card__title">Málaga Collection</h3>
          <p class="laylada-card__text">Lightweight summer modestwear for holidays, cafés, city breaks, and resort moments.</p>
          <span class="laylada-link">Explore Málaga</span>
        </div>
      </a>
      <a class="laylada-card" href="{{ routes.collections_url }}/new-arrivals">
        <div class="laylada-media" aria-hidden="true"></div>
        <div class="laylada-card__body">
          <h3 class="laylada-card__title">New Arrivals</h3>
          <p class="laylada-card__text">Fresh seasonal pieces designed for modern modest wardrobes and effortless styling.</p>
          <span class="laylada-link">Shop new</span>
        </div>
      </a>
      <a class="laylada-card" href="{{ routes.collections_url }}/best-sellers">
        <div class="laylada-media" aria-hidden="true"></div>
        <div class="laylada-card__body">
          <h3 class="laylada-card__title">Best Sellers</h3>
          <p class="laylada-card__text">Customer-loved edits that balance everyday wearability with premium elegance.</p>
          <span class="laylada-link">Shop best sellers</span>
        </div>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Laylada category showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the Laylada wardrobe"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Begin with the collection that matches her moment: Dubai polish, Málaga ease, newness, or proven best sellers."
    }
  ],
  "presets": [
    {
      "name": "Laylada category showcase"
    }
  ]
}
{% endschema %}
