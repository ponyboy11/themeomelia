{%- liquid
  assign has_mobile_media = false
  if section.settings.mobile_video != blank or section.settings.mobile_image != blank
    assign has_mobile_media = true
  endif

  assign has_custom_media = false
  if has_mobile_media or section.settings.section_video != blank or section.settings.section_image != blank
    assign has_custom_media = true
  endif
-%}

<section class="laylada-section">
  <div class="laylada-spotlight">
    <div class="laylada-container">
      <div class="laylada-grid laylada-grid--2">
        <div class="laylada-media{% if has_custom_media %} laylada-media--custom{% endif %}{% if has_mobile_media %} laylada-media--has-mobile{% endif %}"{% unless has_custom_media %} aria-hidden="true"{% endunless %}>
  {%- if has_custom_media -%}
    {%- if section.settings.mobile_video != blank -%}
      {{ section.settings.mobile_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '900x', class: 'laylada-media__asset laylada-media__asset--mobile' }}
    {%- elsif section.settings.mobile_image != blank -%}
      {{ section.settings.mobile_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', sizes: '(max-width: 767px) 100vw, 50vw', alt: section.settings.heading, class: 'laylada-media__asset laylada-media__asset--mobile' }}
    {%- endif -%}

    {%- if section.settings.section_video != blank -%}
      {{ section.settings.section_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '1600x', class: 'laylada-media__asset laylada-media__asset--desktop' }}
    {%- elsif section.settings.section_image != blank -%}
      {{ section.settings.section_image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '720, 960, 1200, 1600', sizes: '(min-width: 768px) 50vw, 100vw', alt: section.settings.heading, class: 'laylada-media__asset laylada-media__asset--desktop' }}
    {%- endif -%}
  {%- endif -%}
</div>
        <div>
          {% if section.settings.eyebrow_text != blank %}<p class="laylada-eyebrow">{{ section.settings.eyebrow_text }}</p>{% endif %}
          {% if section.settings.heading != blank %}<h2 class="laylada-heading">{{ section.settings.heading }}</h2>{% endif %}
          {% if section.settings.subheading != blank %}<p class="laylada-subheading">{{ section.settings.subheading }}</p>{% endif %}
          <div class="laylada-grid laylada-grid--2 laylada-mt">
            <div class="laylada-card"><div class="laylada-card__body">{% if section.settings.card_1_title != blank %}<h3 class="laylada-card__title">{{ section.settings.card_1_title }}</h3>{% endif %}{% if section.settings.card_1_text != blank %}<p class="laylada-card__text">{{ section.settings.card_1_text }}</p>{% endif %}</div></div>
            <div class="laylada-card"><div class="laylada-card__body">{% if section.settings.card_2_title != blank %}<h3 class="laylada-card__title">{{ section.settings.card_2_title }}</h3>{% endif %}{% if section.settings.card_2_text != blank %}<p class="laylada-card__text">{{ section.settings.card_2_text }}</p>{% endif %}</div></div>
          </div>
          {% if section.settings.button_text != blank %}<a class="laylada-button laylada-button--light" href="{{ section.settings.button_url | default: routes.collections_url }}">{{ section.settings.button_text }}</a>{% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Laylada collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Summer ease, Dubai elegance"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Lead with the Málaga Collection for seasonal demand while the Dubai Collection elevates brand perception and average order value."
    },
    {
      "type": "image_picker",
      "id": "section_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "video",
      "id": "section_video",
      "label": "Desktop video"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile video"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow label",
      "default": "Launch focus"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Card 1 title",
      "default": "Málaga Collection"
    },
    {
      "type": "textarea",
      "id": "card_1_text",
      "label": "Card 1 description",
      "default": "Lightweight chiffon summer fabrics, soft resort colours, and relaxed luxury for warm-weather dressing."
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Card 2 title",
      "default": "Dubai Collection"
    },
    {
      "type": "textarea",
      "id": "card_2_text",
      "label": "Card 2 description",
      "default": "A premium halo collection built around statement abayas, refined kimonos, and elegant occasion wear."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Málaga Collection"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Laylada collection"
    }
  ]
}
{% endschema %}
