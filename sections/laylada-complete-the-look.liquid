{%- liquid
  assign has_mobile_media = false
  if section.settings.mobile_video != blank or section.settings.mobile_image != blank
    assign has_mobile_media = true
  endif

  assign has_custom_media = false
  if has_mobile_media or section.settings.section_video != blank or section.settings.section_image != blank
    assign has_custom_media = true
  endif
-%}

<section class="laylada-section">
  <div class="laylada-container">
    <div class="laylada-header"><div>{% if section.settings.eyebrow_text != blank %}<p class="laylada-eyebrow">{{ section.settings.eyebrow_text }}</p>{% endif %}{% if section.settings.heading != blank %}<h2 class="laylada-heading">{{ section.settings.heading }}</h2>{% endif %}</div>{% if section.settings.subheading != blank %}<p class="laylada-subheading">{{ section.settings.subheading }}</p>{% endif %}</div>
    {% if has_custom_media %}<div class="laylada-section-media"><div class="laylada-media{% if has_custom_media %} laylada-media--custom{% endif %}{% if has_mobile_media %} laylada-media--has-mobile{% endif %}"{% unless has_custom_media %} aria-hidden="true"{% endunless %}>
        {%- if has_custom_media -%}
          {%- if section.settings.mobile_video != blank -%}
            {{ section.settings.mobile_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '900x', class: 'laylada-media__asset laylada-media__asset--mobile' }}
          {%- elsif section.settings.mobile_image != blank -%}
            {{ section.settings.mobile_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', sizes: '(max-width: 767px) 100vw, 50vw', alt: section.settings.heading, class: 'laylada-media__asset laylada-media__asset--mobile' }}
          {%- endif -%}

          {%- if section.settings.section_video != blank -%}
            {{ section.settings.section_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '1600x', class: 'laylada-media__asset laylada-media__asset--desktop' }}
          {%- elsif section.settings.section_image != blank -%}
            {{ section.settings.section_image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '720, 960, 1200, 1600', sizes: '(min-width: 768px) 50vw, 100vw', alt: section.settings.heading, class: 'laylada-media__asset laylada-media__asset--desktop' }}
          {%- endif -%}
        {%- endif -%}
      </div></div>{% endif %}
    <div class="laylada-grid laylada-grid--3">{% for block in section.blocks %}{% if block.type == 'look_step' %}<div class="laylada-card" {{ block.shopify_attributes }}><div class="laylada-media" aria-hidden="true">{% if block.settings.step_image != blank %}{{ block.settings.step_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400, 600, 800', class: 'laylada-media__asset' }}{% endif %}</div><div class="laylada-card__body">{% if block.settings.title != blank %}<h3 class="laylada-card__title">{{ block.settings.title }}</h3>{% endif %}{% if block.settings.description != blank %}<p class="laylada-card__text">{{ block.settings.description }}</p>{% endif %}</div></div>{% endif %}{% endfor %}</div>
    {% if section.settings.button_text != blank %}<a class="laylada-button" href="{{ section.settings.button_url | default: routes.collections_url }}">{{ section.settings.button_text }}</a>{% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Laylada outfit edit",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complete the look"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Guide customers from single-item browsing into styled 2-piece and 3-piece outfits for stronger basket value."
    },
    {
      "type": "image_picker",
      "id": "section_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "video",
      "id": "section_video",
      "label": "Desktop video"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile video"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow label",
      "default": "Outfit edit"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Build your look"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Laylada outfit edit",
      "blocks": [
        {
          "type": "look_step",
          "settings": {
            "title": "The abaya",
            "description": "Begin with a refined modest base from the Dubai or Málaga collection."
          }
        },
        {
          "type": "look_step",
          "settings": {
            "title": "The layer",
            "description": "Add a lightweight kimono or open abaya for movement, coverage, and styling depth."
          }
        },
        {
          "type": "look_step",
          "settings": {
            "title": "The finish",
            "description": "Complete the look with accessories that make the outfit feel intentional and premium."
          }
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "look_step",
      "name": "Look step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step description"
        },
        {
          "type": "image_picker",
          "id": "step_image",
          "label": "Step image"
        }
      ]
    }
  ]
}
{% endschema %}
