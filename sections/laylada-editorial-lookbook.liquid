{%- liquid
  assign has_mobile_media = false
  if section.settings.mobile_video != blank or section.settings.mobile_image != blank
    assign has_mobile_media = true
  endif

  assign has_custom_media = false
  if has_mobile_media or section.settings.section_video != blank or section.settings.section_image != blank
    assign has_custom_media = true
  endif
-%}

<section class="laylada-section">
  <div class="laylada-container">
    <div class="laylada-header">
      <div>
        <p class="laylada-eyebrow">Editorial lookbook</p>
        <h2 class="laylada-heading">{{ section.settings.heading }}</h2>
      </div>
      <p class="laylada-subheading">{{ section.settings.subheading }}</p>
    </div>
    {%- if has_custom_media -%}
      <div class="laylada-section-media">
        <div class="laylada-media{% if has_custom_media %} laylada-media--custom{% endif %}{% if has_mobile_media %} laylada-media--has-mobile{% endif %}"{% unless has_custom_media %} aria-hidden="true"{% endunless %}>
          {%- if has_custom_media -%}
            {%- if section.settings.mobile_video != blank -%}
              {{ section.settings.mobile_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '900x', class: 'laylada-media__asset laylada-media__asset--mobile' }}
            {%- elsif section.settings.mobile_image != blank -%}
              {{ section.settings.mobile_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', sizes: '(max-width: 767px) 100vw, 50vw', alt: section.settings.heading, class: 'laylada-media__asset laylada-media__asset--mobile' }}
            {%- endif -%}

            {%- if section.settings.section_video != blank -%}
              {{ section.settings.section_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '1600x', class: 'laylada-media__asset laylada-media__asset--desktop' }}
            {%- elsif section.settings.section_image != blank -%}
              {{ section.settings.section_image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '720, 960, 1200, 1600', sizes: '(min-width: 768px) 50vw, 100vw', alt: section.settings.heading, class: 'laylada-media__asset laylada-media__asset--desktop' }}
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
    <div class="laylada-grid laylada-grid--3">
      <a class="laylada-card" href="{{ routes.collections_url }}/malaga-collection">
        <div class="laylada-media" aria-hidden="true"></div>
        <div class="laylada-card__body">
          <h3 class="laylada-card__title">Málaga mornings</h3>
          <p class="laylada-card__text">Light chiffon, summer neutrals, and modest silhouettes for cafés and coastal city breaks.</p>
        </div>
      </a>
      <a class="laylada-card" href="{{ routes.collections_url }}/dubai-collection">
        <div class="laylada-media" aria-hidden="true"></div>
        <div class="laylada-card__body">
          <h3 class="laylada-card__title">Dubai evenings</h3>
          <p class="laylada-card__text">Polished abayas, kimonos, and statement pieces for elevated dinners and occasions.</p>
        </div>
      </a>
      <a class="laylada-card" href="{{ routes.collections_url }}/new-arrivals">
        <div class="laylada-media" aria-hidden="true"></div>
        <div class="laylada-card__body">
          <h3 class="laylada-card__title">Everyday elegance</h3>
          <p class="laylada-card__text">Modern modest essentials designed to feel expressive, simple, and wearable through every season.</p>
        </div>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Laylada lookbook",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Outfit stories for every moment"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Editorial styling turns the store into a lifestyle destination and supports outfit-check content for holiday campaigns."
    },
    {
      "type": "image_picker",
      "id": "section_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "video",
      "id": "section_video",
      "label": "Desktop video"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile video"
    }
  ],
  "presets": [
    {
      "name": "Laylada editorial lookbook"
    }
  ]
}
{% endschema %}
