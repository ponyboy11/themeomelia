{%- liquid
  assign has_mobile_media = false
  if section.settings.mobile_video != blank or section.settings.mobile_image != blank
    assign has_mobile_media = true
  endif

  assign has_custom_media = false
  if has_mobile_media or section.settings.section_video != blank or section.settings.section_image != blank
    assign has_custom_media = true
  endif
-%}

<section class="laylada-section">
  <div class="laylada-hero">
    <div class="laylada-container">
      <div class="laylada-hero__content">
        {% if section.settings.eyebrow_text != blank %}
          <p class="laylada-eyebrow">{{ section.settings.eyebrow_text }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h1 class="laylada-heading">{{ section.settings.heading }}</h1>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="laylada-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
        {% if section.blocks.size > 0 %}
          <div class="laylada-pill-list" aria-label="Featured collections">
            {% for block in section.blocks %}
              {% if block.type == 'pill' %}
                <span class="laylada-pill" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
        {% if section.settings.button_text != blank %}
          <a class="laylada-button laylada-button--light" href="{{ section.settings.button_url | default: routes.collections_url }}">{{ section.settings.button_text }}</a>
        {% endif %}
        {% if section.settings.note_text != blank %}
          <p class="laylada-hero__note">{{ section.settings.note_text }}</p>
        {% endif %}
      </div>
      <div class="laylada-media{% if has_custom_media %} laylada-media--custom{% endif %}{% if has_mobile_media %} laylada-media--has-mobile{% endif %}"{% unless has_custom_media %} aria-hidden="true"{% endunless %}>
  {%- if has_custom_media -%}
    {%- if section.settings.mobile_video != blank -%}
      {{ section.settings.mobile_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '900x', class: 'laylada-media__asset laylada-media__asset--mobile' }}
    {%- elsif section.settings.mobile_image != blank -%}
      {{ section.settings.mobile_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', sizes: '(max-width: 767px) 100vw, 50vw', alt: section.settings.heading, class: 'laylada-media__asset laylada-media__asset--mobile' }}
    {%- endif -%}

    {%- if section.settings.section_video != blank -%}
      {{ section.settings.section_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '1600x', class: 'laylada-media__asset laylada-media__asset--desktop' }}
    {%- elsif section.settings.section_image != blank -%}
      {{ section.settings.section_image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '720, 960, 1200, 1600', sizes: '(min-width: 768px) 50vw, 100vw', alt: section.settings.heading, class: 'laylada-media__asset laylada-media__asset--desktop' }}
    {%- endif -%}
  {%- endif -%}
</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Laylada hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Where modest meets modern"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "At Laylada, we bridge modest wear and modern Western fashion — creating styles that are inclusive, elegant, and wearable for every woman, every season."
    },
    {
      "type": "image_picker",
      "id": "section_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "video",
      "id": "section_video",
      "label": "Desktop video"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile video"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow label",
      "default": "LAYLADA"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop new arrivals"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "note_text",
      "label": "Footer note",
      "default": "Where modest meets modern"
    }
  ],
  "presets": [
    {
      "name": "Laylada hero",
      "blocks": [
        {
          "type": "pill",
          "settings": {
            "label": "Dubai Collection"
          }
        },
        {
          "type": "pill",
          "settings": {
            "label": "Málaga Collection"
          }
        },
        {
          "type": "pill",
          "settings": {
            "label": "New Arrivals"
          }
        },
        {
          "type": "pill",
          "settings": {
            "label": "Best Sellers"
          }
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Pill",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Pill label"
        }
      ]
    }
  ]
}
{% endschema %}
