{%- liquid
  assign has_mobile_media = false
  if section.settings.mobile_video != blank or section.settings.mobile_image != blank
    assign has_mobile_media = true
  endif

  assign has_custom_media = false
  if has_mobile_media or section.settings.section_video != blank or section.settings.section_image != blank
    assign has_custom_media = true
  endif
-%}

<section class="laylada-section">
  <div class="laylada-container">
    <div class="laylada-header"><div>{% if section.settings.eyebrow_text != blank %}<p class="laylada-eyebrow">{{ section.settings.eyebrow_text }}</p>{% endif %}{% if section.settings.heading != blank %}<h2 class="laylada-heading">{{ section.settings.heading }}</h2>{% endif %}</div>{% if section.settings.subheading != blank %}<p class="laylada-subheading">{{ section.settings.subheading }}</p>{% endif %}</div>
    {% if has_custom_media %}<div class="laylada-section-media"><div class="laylada-media{% if has_custom_media %} laylada-media--custom{% endif %}{% if has_mobile_media %} laylada-media--has-mobile{% endif %}"{% unless has_custom_media %} aria-hidden="true"{% endunless %}>
        {%- if has_custom_media -%}
          {%- if section.settings.mobile_video != blank -%}
            {{ section.settings.mobile_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '900x', class: 'laylada-media__asset laylada-media__asset--mobile' }}
          {%- elsif section.settings.mobile_image != blank -%}
            {{ section.settings.mobile_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', sizes: '(max-width: 767px) 100vw, 50vw', alt: section.settings.heading, class: 'laylada-media__asset laylada-media__asset--mobile' }}
          {%- endif -%}

          {%- if section.settings.section_video != blank -%}
            {{ section.settings.section_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '1600x', class: 'laylada-media__asset laylada-media__asset--desktop' }}
          {%- elsif section.settings.section_image != blank -%}
            {{ section.settings.section_image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '720, 960, 1200, 1600', sizes: '(min-width: 768px) 50vw, 100vw', alt: section.settings.heading, class: 'laylada-media__asset laylada-media__asset--desktop' }}
          {%- endif -%}
        {%- endif -%}
      </div></div>{% endif %}
    <div class="laylada-grid laylada-grid--3">{% for block in section.blocks %}{% if block.type == 'testimonial' %}<div class="laylada-card" {{ block.shopify_attributes }}><div class="laylada-card__body">{% if block.settings.quote != blank %}<p class="laylada-quote">“{{ block.settings.quote }}”</p>{% endif %}{% if block.settings.author_name != blank %}<p class="laylada-card__author">— {{ block.settings.author_name }}{% if block.settings.author_location != blank %}, {{ block.settings.author_location }}{% endif %}</p>{% endif %}{% if block.settings.body_text != blank %}<p class="laylada-card__text">{{ block.settings.body_text }}</p>{% endif %}</div></div>{% endif %}{% endfor %}</div>
  </div>
</section>

{% schema %}
{
  "name": "Laylada testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made for confidence, elegance, and ease"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Use this section for real customer reviews after launch. For now, it frames the emotional transformation Laylada is built to deliver."
    },
    {
      "type": "image_picker",
      "id": "section_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "video",
      "id": "section_video",
      "label": "Desktop video"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile video"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow label",
      "default": "Client mood"
    }
  ],
  "presets": [
    {
      "name": "Laylada testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "Modest, polished, and easy to style.",
            "body_text": "A refined wardrobe feeling for women who want contemporary modest fashion without losing softness."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Elegant enough for dinner, relaxed enough for travel.",
            "body_text": "The right balance for European city breaks, Dubai-inspired evenings, and everyday confidence."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "A complete look, not just one piece.",
            "body_text": "Designed to help customers build outfits around abayas, kimonos, dresses, and seasonal layers."
          }
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "quote",
          "label": "Quote text"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name"
        },
        {
          "type": "text",
          "id": "author_location",
          "label": "Author location (optional)"
        },
        {
          "type": "textarea",
          "id": "body_text",
          "label": "Supporting text"
        }
      ]
    }
  ]
}
{% endschema %}
