{%- liquid
  assign section_anchor = section.settings.section_id | default: section.id
  assign width_class = 'laylada-section--' | append: section.settings.section_width
  assign layout_class = 'laylada-layout--' | append: section.settings.layout_direction
  assign alignment_class = 'laylada-align--' | append: section.settings.content_alignment
  assign position_class = 'laylada-position--' | append: section.settings.content_position
-%}

{%- unless section.settings.hide_section -%}
  <section
    id="{{ section_anchor | handle }}"
    class="laylada-section section-{{ section.id }} {{ width_class }} {{ layout_class }} {{ alignment_class }} {{ position_class }}{% unless section.settings.show_on_desktop %} laylada-hide-desktop{% endunless %}{% unless section.settings.show_on_mobile %} laylada-hide-mobile{% endunless %}"
    aria-label="{{ section.settings.aria_label | default: section.settings.heading | escape }}"
    style="--section-bg: {{ section.settings.color_background }}; --section-text: {{ section.settings.color_text }}; --section-heading: {{ section.settings.color_heading }}; --section-accent: {{ section.settings.color_accent }}; --section-radius: {{ section.settings.border_radius }}px; --section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px; --section-margin-top: {{ section.settings.margin_top }}px; --section-margin-bottom: {{ section.settings.margin_bottom }}px; --heading-size-desktop: {{ section.settings.heading_font_size_desktop }}px; --heading-size-mobile: {{ section.settings.heading_font_size_mobile }}px; --body-size: {{ section.settings.body_font_size }}px; --eyebrow-size: {{ section.settings.eyebrow_font_size }}px; --overlay-color: {{ section.settings.overlay_color }}; --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
  >
    <div class="laylada-container">
    <div class="laylada-header">
      <div class="laylada-header__content">
        {%- if section.settings.eyebrow_text != blank -%}
          <p class="laylada-eyebrow">{{ section.settings.eyebrow_text | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="laylada-heading">{{ section.settings.heading | escape }}</{{ section.settings.heading_tag }}>
        {%- endif -%}
      </div>
      <div class="laylada-header__copy">
        {%- if section.settings.subheading != blank -%}
          <p class="laylada-subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="laylada-richtext">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    </div>
      {%- if section.settings.section_image != blank or section.settings.section_video != blank or section.settings.mobile_image != blank or section.settings.mobile_video != blank -%}
        <div class="laylada-section-media">
          {% render 'laylada-media', media: section.settings, alt: section.settings.image_alt | default: section.settings.heading %}
        </div>
      {%- endif -%}
      <div class="laylada-grid laylada-grid--{{ section.settings.columns_desktop }}">
        {%- for block in section.blocks -%}
          <article class="laylada-card" style="--card-bg: {{ block.settings.color_background }}; --card-text: {{ block.settings.color_text }}; --card-accent: {{ block.settings.color_accent }};" {{ block.shopify_attributes }}>
            {% render 'laylada-media', media: block.settings, alt: block.settings.image_alt | default: block.settings.heading %}
            <div class="laylada-card__body">
              {%- if block.settings.eyebrow_text != blank -%}<p class="laylada-eyebrow">{{ block.settings.eyebrow_text | escape }}</p>{%- endif -%}
              {%- if block.settings.heading != blank -%}<h3 class="laylada-card__title">{{ block.settings.heading | escape }}</h3>{%- endif -%}
              {%- if block.settings.description != blank -%}<div class="laylada-card__text">{{ block.settings.description }}</div>{%- endif -%}
              {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}<a class="laylada-button laylada-button--{{ block.settings.button_style }}" href="{{ block.settings.button_link }}">{{ block.settings.button_label | escape }}</a>{%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endunless -%}

