<section class="laylada-section">
  <div class="laylada-container laylada-container--compact">
    <div class="laylada-header">
      <div>
        <p class="laylada-eyebrow">Shop with confidence</p>
        <h2 class="laylada-heading">{{ section.settings.heading }}</h2>
      </div>
      <p class="laylada-subheading">{{ section.settings.subheading }}</p>
    </div>
    <div class="laylada-trust-bar" aria-label="Laylada trust points">
      <div class="laylada-trust-item">Free EU Shipping</div>
      <div class="laylada-trust-item">30-Day Returns</div>
      <div class="laylada-trust-item">Secure Checkout</div>
      <div class="laylada-trust-item">Ethically Sourced</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Laylada trust section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Luxury feeling, clear purchase confidence"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Free EU Shipping · 30-Day Returns · Secure Checkout · Ethically Sourced"
    }
  ],
  "presets": [
    {
      "name": "Laylada trust section"
    }
  ]
}
{% endschema %}
